# KCBlendz environment configuration
# Copy to .env and fill in real values. Never commit .env.

# Flask secret key — used to sign sessions. Generate with: py -c "import secrets;print(secrets.token_hex(32))"
KCB_SECRET=changeme-please

# Path to SQLite database file (defaults to ./kcblendz.db)
KCB_DB_PATH=./kcblendz.db

# Set to "1" in production behind HTTPS to mark session cookies Secure
KCB_FORCE_SECURE=0

# Web server port (Railway / Heroku will inject this automatically)
PORT=5000
